{
	"name": "typescript-api-extractor",
	"version": "1.0.0-beta.4",
	"description": "Extracts API description from TypeScript code",
	"author": {
		"name": "Michał Dudak",
		"email": "michal@dudak.me"
	},
	"engines": {
		"node": ">=22"
	},
	"files": [
		"dist"
	],
	"main": "dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/michaldudak/typescript-api-extractor.git"
	},
	"scripts": {
		"prebuild": "rimraf ./dist",
		"build": "tsc --project tsconfig.json",
		"typecheck": "tsc --project tsconfig.typecheck.json",
		"typecheck:test-inputs": "tsc --project test/tsconfig.inputs.json",
		"test": "vitest",
		"test:regen": "cross-env UPDATE_OUTPUT=true vitest run",
		"prepack": "pnpm build",
		"lint": "eslint . && prettier --check .",
		"prettier": "prettier --write ."
	},
	"dependencies": {
		"es-toolkit": "^1.49.0",
		"typescript": "^5.8 || ^6.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^22.20.0",
		"@types/react": "^19.2.17",
		"cross-env": "^10.1.0",
		"eslint": "^10.7.0",
		"fast-glob": "^3.3.3",
		"globals": "^17.7.0",
		"prettier": "^3.9.5",
		"rimraf": "^6.1.3",
		"tsx": "^4.23.1",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	},
	"publishConfig": {
		"access": "public"
	},
	"packageManager": "pnpm@11.11.0"
}
