{
	"name": "typescript-api-extractor",
	"version": "1.0.0-beta.3",
	"description": "Extracts API description from TypeScript code",
	"author": {
		"name": "Michał Dudak",
		"email": "michal@dudak.me"
	},
	"engines": {
		"node": ">=22"
	},
	"files": [
		"dist"
	],
	"main": "dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/michaldudak/typescript-api-extractor.git"
	},
	"scripts": {
		"prebuild": "rimraf ./dist",
		"build": "tsc --project tsconfig.json",
		"test": "vitest",
		"test:regen": "cross-env UPDATE_OUTPUT=true vitest run",
		"prepack": "pnpm build",
		"lint": "eslint . && prettier --check .",
		"prettier": "prettier --write ."
	},
	"dependencies": {
		"es-toolkit": "^1.46.0"
	},
	"peerDependencies": {
		"typescript": "^5.8"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^22.19.17",
		"@types/react": "^19.2.14",
		"cross-env": "^10.1.0",
		"eslint": "^10.2.1",
		"fast-glob": "^3.3.3",
		"globals": "^17.5.0",
		"prettier": "^3.8.3",
		"rimraf": "^6.1.3",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.58.2",
		"vite": "^8.0.10",
		"vitest": "^4.1.4"
	},
	"publishConfig": {
		"access": "public"
	},
	"packageManager": "pnpm@10.33.2"
}
