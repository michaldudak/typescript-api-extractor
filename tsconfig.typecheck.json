{
	"compilerOptions": {
		"target": "ES2022",
		"moduleResolution": "bundler",
		"module": "ESNext",
		"jsx": "react-jsx",

		"strict": true,
		"noEmit": true,

		"esModuleInterop": true,
		"isolatedModules": true,
		"types": ["node", "vitest"]
	},
	"include": ["src/**/*.ts", "test/**/*.ts"],
	"exclude": ["test/fixtures/**/*"]
}
